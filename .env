# Google Gemini AI — get your free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB connection string (optional — only needed for cloud sync)
# Free tier: https://cloud.mongodb.com/  → create cluster → get connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/calories-tracker?retryWrites=true&w=majority

# Vite exposes env vars prefixed with VITE_ to the browser
# These are used by the frontend (do NOT put secrets here)
VITE_APP_NAME=Calories Tracker
